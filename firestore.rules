rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == 'admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == 'owner'))
          ||
          request.auth.token.admin == true
        );
    }

    // --- Collection Rules ---

    // USERS: Admins/Owners have absolute access. Users can read/update their own profile.
    match /users/{userId} {
      allow get: if request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if isAdmin() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'subscriptionExpiresAt']));
      allow delete: if isAdmin();
    }

    // TRANSACTIONS: Admins have full access. Users only their own.
    match /transactions/{transactionId} {
      allow get: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
    }

    // GOALS: Admins have full access. Users only their own.
    match /goals/{goalId} {
      allow get: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
    }
  }
}
