rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserDoc(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Assumes we define roles in user tokens, or we let them read from users once.
      // Since rules are simple for now, we verify admin via reading the user's document.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isUserDoc(userId) || isAdmin());
      allow create: if isAuthenticated() && isUserDoc(userId);
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isUserDoc(userId) && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'subscriptionExpiresAt']))
      );
    }

    // Financial Data: transactions collection
    match /transactions/{transactionId} {
      // Only the user who owns the transaction can access it. Admins excluded per instruction.
      allow read, write: if isAuthenticated() && request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid;
    }

    // Financial Data: goals collection
    match /goals/{goalId} {
      // Only the user who owns the goal can access it. Admins excluded per instruction.
      allow read, write: if isAuthenticated() && request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid;
    }
  }
}
