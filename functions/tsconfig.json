{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitAny": false,
    "skipLibCheck": true,
    "outDir": "lib",
    "preserveConstEnums": true,
    "removeComments": true,
    "sourceMap": true,
    "target": "es2018",
    "lib": ["es2018"],
    "types": ["node"]
  },
  "include": [
    "src/**/*"
  ]
}
